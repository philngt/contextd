{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "contextd-retrieval-map",
  "title": "contextd Retrieval Map",
  "description": "Normalized shape for packs/{pack}/agents/pipeline/retrieval-map.md rows.",
  "type": "object",
  "required": ["pack", "rows"],
  "properties": {
    "pack": {
      "type": "string"
    },
    "rows": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["component", "docs"],
        "properties": {
          "component": {
            "type": "string"
          },
          "docs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
