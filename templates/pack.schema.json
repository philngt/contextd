{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "contextd-pack",
  "title": "contextd Pack Manifest",
  "description": "Focused schema for packs/{pack}/pack.yaml normalized shape.",
  "type": "object",
  "required": ["name", "version", "components"],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^pack-[a-z0-9][a-z0-9-]*$"
    },
    "version": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "keywords": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "files": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "conflicts_with": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
